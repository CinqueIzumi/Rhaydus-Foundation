<?xml version="1.0" encoding="UTF-8"?>
<!--
  Shared lint configuration for every module (referenced via `lintConfig` in the Android library
  convention plugin and in :app). Lint runs with `warningsAsErrors = true`, so any new warning fails
  the build; the only checks disabled here are ones that are not actionable code-quality signals.
-->
<lint>
    <!--
      Typos fires exclusively on the opaque base64 font-certificate hashes in res/values/font_certs.xml
      (e.g. "DQEBBAUAMIGU…"). There is nothing to "spell-correct" in a certificate hash, so the check
      is pure noise here, not a code-quality signal.
    -->
    <issue id="Typos" severity="ignore" />

    <!--
      OldTargetApi: bumping targetSdk is a release decision that needs device testing (it changes
      runtime behaviour around permissions and background limits), not something to fold into a lint
      pass. TODO (short-term): bump targetSdk to the latest stable, re-test, then remove this entry.
    -->
    <issue id="OldTargetApi" severity="ignore" />
</lint>
